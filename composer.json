{
    "name": "mauricioperera/php-vector-store",
    "description": "Zero-dependency PHP vector database with BM25, hybrid search, Matryoshka, IVF indexing, and Int8 quantization",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "keywords": ["vector", "embedding", "search", "bm25", "hybrid", "matryoshka", "ivf", "cosine-similarity", "ai", "rag", "neuron"],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "suggest": {
        "neuron-ai/neuron-ai": "For RAG integration via NeuronVectorStore adapter"
    },
    "autoload": {
        "psr-4": {
            "PHPVectorStore\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PHPVectorStore\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "stable"
}
