{
    "name": "mauricioperera/php-vector-store",
    "description": "Zero-dependency PHP vector database with BM25, hybrid search, Matryoshka, IVF indexing, and Int8 quantization",
    "type": "library",
    "license": "MIT",
    "keywords": ["vector", "embedding", "search", "bm25", "hybrid", "matryoshka", "ivf", "cosine-similarity", "ai", "rag", "neuron"],
    "authors": [
        {
            "name": "Mauricio Perera",
            "homepage": "https://github.com/MauricioPerera",
            "role": "Developer"
        }
    ],
    "homepage": "https://github.com/MauricioPerera/php-vector-store",
    "support": {
        "issues": "https://github.com/MauricioPerera/php-vector-store/issues",
        "source": "https://github.com/MauricioPerera/php-vector-store"
    },
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "suggest": {
        "neuron-core/neuron-ai": "For RAG integration via NeuronVectorStore adapter"
    },
    "autoload": {
        "psr-4": {
            "PHPVectorStore\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PHPVectorStore\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
